{
  "name": "yeelight-cli",
  "version": "0.1.0",
  "private": false,
  "description": "Bun-first TypeScript CLI and library for controlling Yeelight bulbs over LAN",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "yeelight": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepare": "bun run build",
    "start": "bun run src/cli.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
